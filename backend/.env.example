# Smart Budget - Environment Variables

NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/smart_budget?schema=public"

JWT_SECRET=your_super_secret_jwt_key_min_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_characters
JWT_REFRESH_EXPIRES_IN=30d

CLIENT_URL=http://localhost:5173

UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880

ADMIN_EMAIL=admin@smartbudget.com
ADMIN_PASSWORD=Admin@123456
ADMIN_USERNAME=admin
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
